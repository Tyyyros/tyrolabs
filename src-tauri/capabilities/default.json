{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capacités par défaut de la fenêtre principale",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
    "store:allow-get",
    "store:allow-set",
    "store:allow-load",
    "store:allow-save",
    "store:allow-delete",
    "store:allow-clear"
  ]
}
